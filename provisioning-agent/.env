# development | test | production
NODE_ENV=development
PORT=8080

# Minimum 16 characters; authenticates callers to this service.
PROVISIONING_API_TOKEN=dev-only-provisioning-api-token-min-16

# Minimum 8 characters; ERP admin password for bench commands.
ERP_ADMIN_PASSWORD=dev-only-erp-admin-password

# Path to the Frappe bench directory on the host (docker backend).
ERP_BENCH_PATH=/home/frappe/frappe-bench

# bench CLI name.
ERP_BENCH_EXECUTABLE=bench

# ERPNext backend container name (docker backend).
ERP_CONTAINER_NAME=axiserp-erpnext-pnzjyk-backend-1

# Base domain appended to site names (e.g. tenant.example.com).
ERP_BASE_DOMAIN=erp.example.internal

# Prefix for API usernames created during provisioning.
ERP_API_USERNAME_PREFIX=cp

# Per-command timeout in milliseconds.
ERP_COMMAND_TIMEOUT_MS=120000

# docker (bench on host/container) | remote (HTTP to erp-execution-service)
ERP_EXECUTION_BACKEND=docker

# Required when ERP_EXECUTION_BACKEND=remote:
# ERP_REMOTE_BASE_URL=http://erp-execution-service:8790
# ERP_REMOTE_TOKEN=dev-only-remote-shared-token-min-16
# ERP_REMOTE_TIMEOUT_MS=15000
