# development | test | production
NODE_ENV=production

# Host port published by Compose; app listens on the same port inside the container.
PORT=8790

# Bearer secret shared with provisioning-agent (minimum 16 characters).
ERP_REMOTE_TOKEN=dev-only-remote-token-min-16-chars

# ERPNext admin password for provisioning API calls (minimum 8 characters).
ERP_ADMIN_PASSWORD=dev-only-erp-admin-password

# ERPNext base URL reachable from this service (e.g. http://axis-erp-backend:8000).
ERP_BASE_URL=http://axis-erp-backend:8000

# Per-action HTTP timeout in milliseconds.
ERP_COMMAND_TIMEOUT_MS=120000
