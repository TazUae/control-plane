# =============================================================================
# Schema template (safe placeholders only). Copy to `.env` for local dev.
# Production: set these keys in Dokploy — do not rely on a committed `.env` file.
# =============================================================================

# --- PostgreSQL (control-plane-postgres) ---
# Database name and role created inside the container.
POSTGRES_DB=controlplane
POSTGRES_USER=cp_user
# Must match the password embedded in DATABASE_URL.
POSTGRES_PASSWORD=dev-only-postgres-password

# --- Control plane API and worker ---
# development | test | production
NODE_ENV=production
PORT=4000

# Prisma URL; hostname must be control-plane-postgres on the Compose network.
DATABASE_URL=postgresql://cp_user:dev-only-postgres-password@control-plane-postgres:5432/controlplane

REDIS_URL=redis://control-plane-redis:6379

# Minimum 16 characters; API authentication.
CONTROL_PLANE_API_KEY=dev-only-control-plane-api-key-min-16

# Provisioning agent (required when NODE_ENV is production).
PROVISIONING_API_URL=http://provisioning-agent:8080
PROVISIONING_API_TOKEN=dev-only-provisioning-token-min-16

# Optional; default in application if omitted.
PROVISIONING_API_TIMEOUT_MS=120000

# Optional; true or false — extra ERP db_name validation after provisioning.
PROVISIONING_VALIDATE_ERP_DB_ON_COMPLETE=false
