node_modules/
dist/
tmp/
*.log

# Sibling-service copies must never be re-tracked in this repo (repo-boundary
# pollution cleanup — see chore/cp-remove-nested-service-copies).
/erp-execution-service/
/provisioning-agent/
/erp-worker/
/packages/erp-utils/

# Local env (never commit). Copy from `.env.example` for development.
.env
.env.local
.env.production
.env.secrets
# Catch-all for other dotenv variants (e.g. .env.bak.YYYYMMDD) and backup files;
# keep checked-in example templates.
.env.*
!.env*.example
*.bak
